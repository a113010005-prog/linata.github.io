---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="zh-Hant">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red: #DC2626;
      --red-light: #EF4444;
      --blue: #1E40AF;
      --bg: #FFFAF9;
      --text: #450A0A;
      --muted: #78716C;
      --border: #E7E5E4;
    }
    body {
      font-family: 'Roboto', 'PingFang TC', 'Noto Sans TC', sans-serif;
      background: var(--bg);
      color: var(--text);
      margin: 0;
    }
    .hero {
      border-bottom: 3px solid var(--red);
      padding: 4rem 2rem 3rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .hero-label {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1rem;
    }
    .hero-title {
      font-family: 'Newsreader', 'Noto Serif TC', Georgia, serif;
      font-size: clamp(2.5rem, 8vw, 6rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
      margin: 0 0 1.5rem;
    }
    .hero-desc {
      font-size: clamp(1rem, 2vw, 1.2rem);
      line-height: 1.8;
      color: var(--muted);
      max-width: 640px;
      margin: 0 0 2rem;
    }
    .hero-cta {
      display: inline-block;
      background: var(--red);
      color: white;
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.75rem 2rem;
      text-decoration: none;
      transition: background 200ms;
      cursor: pointer;
    }
    .hero-cta:hover {
      background: var(--red-light);
    }
    .latest {
      max-width: 1100px;
      margin: 3rem auto;
      padding: 0 2rem;
    }
    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.5rem;
      margin-bottom: 2rem;
    }
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
    }
    .post-card {
      border-top: 2px solid var(--text);
      padding-top: 1rem;
      text-decoration: none;
      color: inherit;
      display: block;
      transition: border-color 200ms;
      cursor: pointer;
    }
    .post-card:hover {
      border-color: var(--red);
    }
    .post-date {
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }
    .post-title {
      font-family: 'Newsreader', 'Noto Serif TC', Georgia, serif;
      font-size: 1.3rem;
      font-weight: 600;
      line-height: 1.3;
      margin: 0 0 0.5rem;
    }
    .post-desc {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.6;
    }
    @media (max-width: 600px) {
      .hero { padding: 2rem 1rem; }
      .latest { padding: 0 1rem; }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <section class="hero">
      <div class="hero-label">娜塔莎新聞網</div>
      <h1 class="hero-title">關注正在<br>發生的世界</h1>
      <p class="hero-desc">
        這裡關注的不只是新聞事件本身，更希望透過文字，帶你理解事件背後的故事與影響。從校園大小事、社會時事，到網路話題與人物觀察，我們用年輕世代的視角，快速整理重點、深入追蹤議題。
      </p>
      <a href="/blog" class="hero-cta">閱讀最新文章</a>
    </section>

    <section class="latest">
      <div class="section-label">最新報導</div>
      <div class="posts-grid">
        {posts.map(post => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-date">{post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
            <div class="post-title">{post.data.title}</div>
            <div class="post-desc">{post.data.description}</div>
          </a>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>
